<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:icon="@mipmap/ic_launcher_default"
        android:roundIcon="@mipmap/ic_launcher_default_round"
        android:label="@string/app_name"
        tools:replace="android:icon,android:roundIcon">
        <activity
            android:name="com.yiqiu.shirohaquiz.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            tools:replace="android:exported" />

        <activity-alias
            android:name="com.yiqiu.shirohaquiz.DefaultLauncher"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_default"
            android:roundIcon="@mipmap/ic_launcher_default_round"
            android:label="@string/app_name"
            android:targetActivity="com.yiqiu.shirohaquiz.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name="com.yiqiu.shirohaquiz.ShirohaLauncher"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_shiroha"
            android:roundIcon="@mipmap/ic_launcher_shiroha_round"
            android:label="@string/app_name"
            android:targetActivity="com.yiqiu.shirohaquiz.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>
</manifest>
