{
  "app": "Shiroha Quiz",
  "scope": "native-parser-regression",
  "version": 2,
  "note": "外部回归核对包，不改 Android 源码和现有单元测试。Runner 以本 manifest 为唯一用例清单。",
  "cases": [
    {
      "id": "01_standard_single",
      "mode": "single",
      "sample": "samples/01_standard_single.txt",
      "expected": "expected/01_standard_single.json",
      "risk": "标准题不应被复杂策略误伤"
    },
    {
      "id": "02_two_option_single",
      "mode": "single",
      "sample": "samples/02_two_option_single.txt",
      "expected": "expected/02_two_option_single.json",
      "risk": "A 正确 / B 错误 两选项单选不能误判为判断题"
    },
    {
      "id": "03_trailing_judge",
      "mode": "single",
      "sample": "samples/03_trailing_judge.txt",
      "expected": "expected/03_trailing_judge.json",
      "risk": "无选项题尾判断答案应识别为判断题"
    },
    {
      "id": "04_answer_section",
      "mode": "single",
      "sample": "samples/04_answer_section.txt",
      "expected": "expected/04_answer_section.json",
      "risk": "答案解析区不能被解析成新题"
    },
    {
      "id": "05_dual_file",
      "mode": "dual",
      "questionSample": "samples/05_dual_questions.txt",
      "answerSample": "samples/05_dual_answers.txt",
      "expected": "expected/05_dual_file.json",
      "risk": "双文件导入应优先按题号合并"
    },
    {
      "id": "06_subjective_text_answer",
      "mode": "single",
      "sample": "samples/06_subjective_text_answer.txt",
      "expected": "expected/06_subjective_text_answer.json",
      "risk": "简答文本答案不能被拆成 A/B/C 选项"
    },
    {
      "id": "07_compact_format",
      "mode": "single",
      "sample": "samples/07_compact_format.txt",
      "expected": "expected/07_compact_format.json",
      "risk": "紧凑格式应拆分题目和选项"
    },
    {
      "id": "08_sectioned_types",
      "mode": "single",
      "sample": "samples/08_sectioned_types.txt",
      "expected": "expected/08_sectioned_types.json",
      "risk": "分区标题应继承题型但不进入题干"
    },
    {
      "id": "09_table_text",
      "mode": "single",
      "sample": "samples/09_table_text.tsv",
      "expected": "expected/09_table_text.json",
      "risk": "表格文本应按列识别题干、选项、答案和解析"
    },
    {
      "id": "10_shared_stem",
      "mode": "single",
      "sample": "samples/10_shared_stem.txt",
      "expected": "expected/10_shared_stem.json",
      "risk": "共用题干/材料题应复制材料到每个子题，不能丢失题干背景"
    },
    {
      "id": "11_shared_stem_answer_section",
      "mode": "single",
      "sample": "samples/11_shared_stem_answer_section.txt",
      "expected": "expected/11_shared_stem_answer_section.json",
      "risk": "共用题干题带答案解析区时，应先拆题再合并答案和解析"
    },
    {
      "id": "12_material_wording_standard_guard",
      "mode": "single",
      "sample": "samples/12_material_wording_standard_guard.txt",
      "expected": "expected/12_material_wording_standard_guard.json",
      "risk": "普通编号题干里出现材料题字样时，不能被兜底策略误重写"
    }
  ]
}
